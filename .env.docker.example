# Copy this file to `.env` and edit it — it is the single place all stack config
# lives. `docker compose` reads `.env` automatically. Do not commit your real .env.

# --- Public entrypoint ---
# Host port people hit; NGINX_PORT is the proxy's internal listen port.
PUBLIC_PORT=8080
NGINX_PORT=80

# --- Postgres ---
POSTGRES_USER=visdom
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=visdom_cloud

# --- Gateway ---
GATEWAY_PORT=8085
# Generate a long random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-secret
# Set True once the proxy terminates HTTPS, so the session cookie is Secure.
COOKIE_SECURE=False
# Public origin (used for CORS); same origin as the proxy.
FRONTEND_URL=http://localhost:8080

# --- Visdom ---
# Build context for the visdom image. Locally the visdom fork is a sibling repo;
# for deployment, point this at wherever the visdom fork is checked out.
VISDOM_CONTEXT=../visdom
VISDOM_PORT=8097
VISDOM_BASE_URL=/vis
VISDOM_ENV_PATH=/data/envs
