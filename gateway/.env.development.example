# Development environment variables template
# Copy this file to '.env' to configure local development settings

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visdom_cloud
COOKIE_SECURE=False
JWT_SECRET=dev-only-insecure-secret-change-me-0123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PORT=8082
