# Production environment variables template
# Copy this file to '.env' or set environment variables in your hosting provider

DATABASE_URL=postgresql://<prod_db_user>:<prod_db_password>@<prod_db_host>:5432/visdom_cloud
COOKIE_SECURE=True
JWT_SECRET=your-super-secret-production-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PORT=8082
